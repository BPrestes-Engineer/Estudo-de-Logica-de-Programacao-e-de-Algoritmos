Algoritmo "Funcao Enquanto com Numeros"

// Descrição   : Estudo da Função Enquanto com números
// Autor(a)    : BrunoP
// Data atual  : 26/06/2026

Var

   numero: inteiro

Inicio

   Escreval ("Digite um Número: ")
   Leia (numero)
   escreval

   Enquanto numero <= 10 Faca
      escreval (numero)
      numero <- numero + 1

   FimEnquanto
   escreval

Fimalgoritmo